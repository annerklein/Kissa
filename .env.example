# Kissa Coffee Tracker - Environment Configuration
# Copy to .env and fill in your values. This file should NEVER be committed.

# =============================================================================
# Raspberry Pi / Deployment
# =============================================================================
RPI_HOST=your-rpi-hostname.local
RPI_USER=your-ssh-username
RPI_PASS=your-ssh-password

# =============================================================================
# Production URLs
# =============================================================================
PROD_API_URL=http://your-rpi-hostname.local:3001
PROD_WEB_URL=http://your-rpi-hostname.local:3000
